# ══════════════════════════════════════════════════
#  JITD AI — Environment Configuration
#  Copy this to .env and fill in your values
#  DO NOT commit .env to git (it's in .gitignore)
# ══════════════════════════════════════════════════

# ── MongoDB ─────────────────────────────────────
# Local dev:
MONGODB_URI=mongodb://localhost:27017/jitd_ai

# Production (MongoDB Atlas - free tier):
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/jitd_ai

MONGO_DB_NAME=jitd_ai

# ── Admin ────────────────────────────────────────
ADMIN_MASTER_KEY=sk-admin-jitd-ai-master-999

# ── Google OAuth (fill in after Google Console setup) ───
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Models ────────────────────────────────────
# Set OLLAMA_MOCK=true to run without Ollama (local dev)
OLLAMA_MOCK=false
OLLAMA_HOST=http://localhost:11434
LLM_MODEL_GENERAL=qwen2.5:14b
LLM_MODEL_CODING=qwen2.5-coder:14b

# ── Server ───────────────────────────────────────
PORT=8000

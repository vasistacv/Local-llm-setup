# COLLEGE AI ENTERPRISE — H200 SERVER CONFIG
# ===========================================

# --- ADMIN SECURITY ---
ADMIN_MASTER_KEY=sk-admin-college-ai-h200-master-999

# --- MODELS (Correct Ollama registry names) ---
# Best models fitting in 15.4GB GPU VRAM (no RAM offloading needed)
LLM_MODEL_GENERAL=qwen2.5:14b

# Best coding model fitting in 15.4GB GPU VRAM
LLM_MODEL_CODING=qwen2.5-coder:14b

# Most advanced vision model available on Ollama
LLM_MODEL_VISION=llama3.2-vision:90b

# --- ENGINE ---
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
LLM_TIMEOUT=300
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=8192
LLM_CONTEXT_WINDOW=32768

# --- SYSTEM ---
MAX_CONVERSATION_HISTORY=100
ENABLE_GPU=true
VERBOSE_LOGGING=true

# --- DATABASE ---
API_DB_PATH=data/memory/api_keys.db
MEMORY_DB_PATH=data/memory/nova.db

# 🚀 COLLEGE AI ENTERPRISE SERVER (H200 CLUSTER OPTIMIZED)
# =========================================================
# Configuration for massive scale H200 GPU infrastructure.

# --- ADMIN API SECURITY ---
# This is the master key to generate user keys. Change this in production!
ADMIN_MASTER_KEY=sk-admin-college-ai-h200-master-999

# --- MASSIVE SCALE MODELS ---
# General Intelligence (Rivals GPT-4 class)
LLM_MODEL_GENERAL=llama3.1:70b

# Supreme Coding Model (State of the Art)
LLM_MODEL_CODING=qwen2.5-coder:72b

# Vision & Multimodal Model (For Image Understanding)
LLM_MODEL_VISION=llama3.2-vision:90b

# --- ENGINE SETTINGS ---
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434
LLM_TIMEOUT=300  # Longer timeout for massive models
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=8192  # Extended generation limit
LLM_CONTEXT_WINDOW=128000  # Massive context window

# --- SYSTEM SETTINGS ---
MAX_CONVERSATION_HISTORY=100
ENABLE_GPU=true
SAFE_MODE=false
VERBOSE_LOGGING=true

# --- DATABASE ---
API_DB_PATH=data/memory/api_keys.db
MEMORY_DB_PATH=data/memory/nova.db
